<?xml version="1.0" encoding="utf-8"?>
<!-- Hero section — included into fragment_home.xml via <include> -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="420dp">

    <!-- ── Backdrop poster image ── -->
    <ImageView
        android:id="@+id/iv_hero_backdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        tools:src="@tools:sample/backgrounds/scenic" />

    <!-- ── Gradient overlay: transparent → surface ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_hero_overlay" />

    <!-- ── Content — pinned to bottom ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingBottom="24dp">

        <!-- Tags row: PREMIERE badge + meta text -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_premiere_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_premiere"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp"
                android:text="PREMIERE"
                android:textColor="@color/primary"
                style="@style/TextAppearance.NeonNoir.LabelCaps" />

            <!-- Dot separator -->
            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/shape_dot"
                android:backgroundTint="@color/on_surface_variant" />

            <TextView
                android:id="@+id/tv_hero_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.NeonNoir.LabelMedium"
                android:textColor="@color/on_surface_variant"
                tools:text="Sci-Fi • 2h 45m • 2049" />

        </LinearLayout>

        <!-- Movie title — large display -->
        <TextView
            android:id="@+id/tv_hero_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="2"
            android:ellipsize="end"
            style="@style/TextAppearance.NeonNoir.DisplayLarge"
            android:textColor="@color/on_surface"
            tools:text="BLADE RUNNER 2049" />

        <!-- Plot excerpt — max 2 lines -->
        <TextView
            android:id="@+id/tv_hero_plot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="2"
            android:ellipsize="end"
            style="@style/TextAppearance.NeonNoir.BodyMedium"
            android:textColor="@color/on_surface_variant"
            tools:text="A young blade runner's discovery of a long-buried secret leads him to track down former blade runner Rick Deckard." />

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="start">

            <!-- Primary CTA: Watch Now -->
            <Button
                android:id="@+id/btn_hero_watch_now"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:background="@drawable/bg_button_primary"
                android:drawableStart="@drawable/ic_play"
                android:drawablePadding="8dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="Watch Now"
                android:textColor="@color/on_primary"
                style="@style/TextAppearance.NeonNoir.Button" />

            <!-- Ghost CTA: + Watchlist -->
            <Button
                android:id="@+id/btn_hero_watchlist"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_button_ghost"
                android:drawableStart="@drawable/ic_add"
                android:drawablePadding="8dp"
                android:drawableTint="@color/on_surface"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="Watchlist"
                android:textColor="@color/on_surface"
                style="@style/TextAppearance.NeonNoir.Button" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>