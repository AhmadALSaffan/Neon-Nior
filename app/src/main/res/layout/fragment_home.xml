<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".presentation.home.HomeFragment">

    <!-- ═══════════════════════════════════════════ -->
    <!-- APP BAR — transparent, scrolls with content -->
    <!-- ═══════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"
            app:layout_scrollFlags="scroll|enterAlways">

            <!-- Hamburger / menu icon -->
            <ImageButton
                android:id="@+id/btn_menu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Menu"
                android:src="@drawable/ic_menu"
                app:tint="@color/on_surface" />

            <!-- Brand name — centred in toolbar -->
            <TextView
                android:id="@+id/tv_brand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Neon Noir"
                android:textColor="@color/primary"
                style="@style/TextAppearance.NeonNoir.HeadlineSmall" />

            <!-- Right-side actions -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Search shortcut -->
                <ImageButton
                    android:id="@+id/btn_toolbar_search"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Search"
                    android:src="@drawable/ic_search"
                    app:tint="@color/on_surface" />

                <!-- User avatar -->
                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="@dimen/avatar_sm"
                    android:layout_height="@dimen/avatar_sm"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/shape_circle"
                    android:contentDescription="Profile"
                    android:scaleType="centerCrop" />

            </LinearLayout>

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ═══════════════════════════════════════════ -->
    <!-- SCROLLABLE CONTENT                          -->
    <!-- ═══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/bottom_nav_height"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ─────────────────────────────────── -->
            <!-- HERO SECTION                        -->
            <!-- ─────────────────────────────────── -->
            <include
                android:id="@+id/hero_section"
                layout="@layout/view_hero_section" />

            <!-- ─────────────────────────────────── -->
            <!-- TRENDING NOW                        -->
            <!-- ─────────────────────────────────── -->
            <include
                android:id="@+id/header_trending"
                layout="@layout/view_section_header" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_trending"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/row_gap"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingStart="@dimen/screen_padding_horizontal"
                android:paddingEnd="@dimen/screen_padding_horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="4"
                tools:listitem="@layout/item_movie_portrait" />

            <!-- ─────────────────────────────────── -->
            <!-- TOP GENRES                          -->
            <!-- ─────────────────────────────────── -->
            <include
                android:id="@+id/header_genres"
                layout="@layout/view_section_header" />

            <!--
                2-column genre grid.
                Using RecyclerView + GridLayoutManager(2) driven by GenreTileAdapter.
                Height is constrained via a custom FixedGridRecyclerView or
                wrap_content with RecyclerView.WRAP_CONTENT trick.
                We set a fixed height here for predictability: 4 tiles × (120dp + 2×12dp gap) = 288dp.
            -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_genres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/row_gap"
                android:layout_marginStart="@dimen/screen_padding_horizontal"
                android:layout_marginEnd="@dimen/screen_padding_horizontal"
                android:nestedScrollingEnabled="false"
                tools:itemCount="4"
                tools:listitem="@layout/item_genre_tile" />

            <!-- ─────────────────────────────────── -->
            <!-- RECENTLY ADDED                      -->
            <!-- ─────────────────────────────────── -->
            <include
                android:id="@+id/header_recent"
                layout="@layout/view_section_header" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/row_gap"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingStart="@dimen/screen_padding_horizontal"
                android:paddingEnd="@dimen/screen_padding_horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="4"
                tools:listitem="@layout/item_movie_portrait" />

            <!-- Bottom breathing room above nav bar -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="@dimen/section_gap" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ═══════════════════════════════════════════ -->
    <!-- LOADING OVERLAY                             -->
    <!-- ═══════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/surface"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/primary" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>