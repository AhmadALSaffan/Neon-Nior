<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused: glowing primary border -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_container_high" />
            <stroke android:width="2dp" android:color="@color/primary" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Default: subtle border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface_container" />
            <stroke android:width="1dp" android:color="@color/surface_container_high" />
            <corners android:radius="12dp" />
        </shape>
    </item>

</selector>