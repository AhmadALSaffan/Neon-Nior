<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_auth"
    app:startDestination="@id/splash_fragment">

    <fragment
        android:id="@+id/splash_fragment"
        android:name="com.neonnoir.presentation.auth.splash.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splash_to_signIn"
            app:destination="@id/sign_in_fragment" />
        <action
            android:id="@+id/action_splash_to_signUp"
            app:destination="@id/sign_up_fragment" />
    </fragment>

    <fragment
        android:id="@+id/sign_in_fragment"
        android:name="com.neonnoir.presentation.auth.signin.SignInFragment"
        android:label="Sign In">
        <action
            android:id="@+id/action_signIn_to_signUp"
            app:destination="@id/sign_up_fragment" />
        <action
            android:id="@+id/action_signIn_to_forgot"
            app:destination="@id/forgot_password_fragment" />
    </fragment>

    <fragment
        android:id="@+id/sign_up_fragment"
        android:name="com.neonnoir.presentation.auth.signup.SignUpFragment"
        android:label="Sign Up">
        <action
            android:id="@+id/action_signUp_to_signIn"
            app:destination="@id/sign_in_fragment"
            app:popUpTo="@id/sign_up_fragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_signUp_to_otp"
            app:destination="@id/otp_fragment" />
    </fragment>

    <fragment
        android:id="@+id/forgot_password_fragment"
        android:name="com.neonnoir.presentation.auth.forgot.ForgotPasswordFragment"
        android:label="Forgot Password">
        <action
            android:id="@+id/action_forgot_to_signIn"
            app:destination="@id/sign_in_fragment"
            app:popUpTo="@id/forgot_password_fragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/otp_fragment"
        android:name="com.neonnoir.presentation.auth.otp.OtpFragment"
        android:label="Verify Access">
        <argument
            android:name="email"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

</navigation>