<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".presentation.detail.DetailFragment">

    <!-- ═══════════════════════════════════════════════ -->
    <!-- COLLAPSING HERO APP BAR                         -->
    <!-- ═══════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="460dp"
        android:background="@color/surface"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:contentScrim="@color/surface"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:statusBarScrim="@color/surface"
            app:titleEnabled="false">

            <!-- Full-bleed backdrop poster -->
            <ImageView
                android:id="@+id/iv_backdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.4"
                tools:src="@tools:sample/backgrounds/scenic" />

            <!-- Gradient overlay: transparent → surface -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_hero_overlay"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.4" />

            <!-- Hero text content pinned to bottom -->
            <LinearLayout
                android:id="@+id/ll_hero_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="@dimen/screen_padding_horizontal"
                android:paddingEnd="@dimen/screen_padding_horizontal"
                android:paddingBottom="20dp"
                app:layout_collapseMode="pin">

                <!-- Tags: genre • runtime • year | rated -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_genre_tag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.NeonNoir.LabelCaps"
                        android:textColor="@color/tertiary"
                        tools:text="SCI-FI" />

                    <View
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/shape_dot"
                        android:backgroundTint="@color/outline_variant" />

                    <TextView
                        android:id="@+id/tv_runtime_tag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.NeonNoir.LabelCaps"
                        android:textColor="@color/tertiary"
                        tools:text="2H 45M" />

                    <View
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/shape_dot"
                        android:backgroundTint="@color/outline_variant" />

                    <TextView
                        android:id="@+id/tv_year_tag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.NeonNoir.LabelCaps"
                        android:textColor="@color/tertiary"
                        tools:text="2024" />

                    <TextView
                        android:id="@+id/tv_rated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_rated_badge"
                        android:paddingStart="7dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="7dp"
                        android:paddingBottom="2dp"
                        style="@style/TextAppearance.NeonNoir.LabelSmall"
                        android:textColor="@color/tertiary"
                        tools:text="PG-13" />

                </LinearLayout>

                <!-- Movie title -->
                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:maxLines="3"
                    android:ellipsize="end"
                    style="@style/TextAppearance.NeonNoir.DisplayLarge"
                    android:textColor="@color/on_surface"
                    tools:text="NEON GENESIS" />

                <!-- IMDb rating -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_star"
                        app:tint="@color/primary"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tv_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        style="@style/TextAppearance.NeonNoir.HeadlineSmall"
                        android:textColor="@color/on_surface"
                        tools:text="8.4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        style="@style/TextAppearance.NeonNoir.BodyMedium"
                        android:textColor="@color/on_surface_variant"
                        android:text="/10" />

                </LinearLayout>

            </LinearLayout>

            <!-- Floating toolbar: back + share — always visible -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@android:color/transparent"
                app:layout_collapseMode="pin">

                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="start"
                    android:background="@drawable/bg_icon_button"
                    android:contentDescription="Back"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/primary" />

                <ImageButton
                    android:id="@+id/btn_share"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="end"
                    android:background="@drawable/bg_icon_button"
                    android:contentDescription="Share"
                    android:src="@drawable/ic_share"
                    app:tint="@color/primary" />

            </com.google.android.material.appbar.MaterialToolbar>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ═══════════════════════════════════════════════ -->
    <!-- SCROLLABLE BODY                                 -->
    <!-- ═══════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/bottom_nav_height"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <!-- ─────────────────────────────── -->
            <!-- ACTION BUTTONS                  -->
            <!-- ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/screen_padding_horizontal"
                android:paddingEnd="@dimen/screen_padding_horizontal"
                android:paddingTop="20dp">

                <Button
                    android:id="@+id/btn_play"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:background="@drawable/bg_button_primary"
                    android:drawableStart="@drawable/ic_play"
                    android:drawablePadding="8dp"
                    android:text="PLAY NOW"
                    android:textColor="@color/on_primary"
                    style="@style/TextAppearance.NeonNoir.Button" />

                <Button
                    android:id="@+id/btn_watchlist"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_button_ghost"
                    android:drawableStart="@drawable/ic_bookmark_outline"
                    android:drawablePadding="8dp"
                    android:drawableTint="@color/on_surface"
                    android:text="+ WATCHLIST"
                    android:textColor="@color/on_surface"
                    style="@style/TextAppearance.NeonNoir.Button" />

            </LinearLayout>

            <!-- ─────────────────────────────── -->
            <!-- PLOT                            -->
            <!-- ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/screen_padding_horizontal"
                android:paddingEnd="@dimen/screen_padding_horizontal"
                android:paddingTop="@dimen/section_gap">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THE GLITCH"
                    style="@style/TextAppearance.NeonNoir.LabelCaps"
                    android:textColor="@color/secondary" />

                <TextView
                    android:id="@+id/tv_plot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    style="@style/TextAppearance.NeonNoir.BodyLarge"
                    android:textColor="@color/on_surface_variant"
                    tools:text="In a world where consciousness can be uploaded to the cloud, one rebel discovers a glitch that could unravel the fabric of digital reality." />

            </LinearLayout>

            <!-- ─────────────────────────────── -->
            <!-- MAIN CAST                       -->
            <!-- ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/screen_padding_horizontal"
                android:paddingEnd="@dimen/screen_padding_horizontal"
                android:paddingTop="@dimen/section_gap">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MAIN CAST"
                    style="@style/TextAppearance.NeonNoir.LabelCaps"
                    android:textColor="@color/secondary" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_cast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="3"
                    tools:listitem="@layout/item_cast_member" />

            </LinearLayout>

            <!-- ─────────────────────────────── -->
            <!-- DIRECTOR + STUDIO               -->
            <!-- ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/screen_padding_horizontal"
                android:paddingEnd="@dimen/screen_padding_horizontal"
                android:paddingTop="@dimen/section_gap">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DIRECTOR"
                    style="@style/TextAppearance.NeonNoir.LabelCaps"
                    android:textColor="@color/on_surface_variant" />

                <TextView
                    android:id="@+id/tv_director"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    style="@style/TextAppearance.NeonNoir.HeadlineSmall"
                    android:textColor="@color/on_surface"
                    tools:text="Denis Villeneuve" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="STUDIO"
                    style="@style/TextAppearance.NeonNoir.LabelCaps"
                    android:textColor="@color/on_surface_variant" />

                <TextView
                    android:id="@+id/tv_studio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    style="@style/TextAppearance.NeonNoir.HeadlineSmall"
                    android:textColor="@color/on_surface"
                    tools:text="Neon Horizon Pictures" />

            </LinearLayout>

            <!-- ─────────────────────────────── -->
            <!-- KEYWORDS                        -->
            <!-- ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/screen_padding_horizontal"
                android:paddingEnd="@dimen/screen_padding_horizontal"
                android:paddingTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KEYWORDS"
                    style="@style/TextAppearance.NeonNoir.LabelCaps"
                    android:textColor="@color/on_surface_variant" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_genres"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:chipSpacingHorizontal="8dp"
                    app:chipSpacingVertical="6dp" />

            </LinearLayout>

            <!-- ─────────────────────────────── -->
            <!-- RELATED MOVIES                  -->
            <!-- ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="@dimen/section_gap">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/screen_padding_horizontal"
                    android:paddingEnd="@dimen/screen_padding_horizontal"
                    android:text="RELATED MOVIES"
                    style="@style/TextAppearance.NeonNoir.HeadlineSmall"
                    android:textColor="@color/on_surface" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_related"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/row_gap"
                    android:paddingStart="@dimen/screen_padding_horizontal"
                    android:paddingEnd="@dimen/screen_padding_horizontal"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="4"
                    tools:listitem="@layout/item_related_movie" />

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="@dimen/section_gap" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>