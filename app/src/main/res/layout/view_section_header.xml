<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable section header — use with <include> and binding.headerId.tvSectionTitle etc. -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/screen_padding_horizontal"
    android:paddingEnd="@dimen/screen_padding_horizontal"
    android:paddingTop="@dimen/section_gap">

    <!-- Title row: section title + optional VIEW ALL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_section_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            style="@style/TextAppearance.NeonNoir.HeadlineSmall"
            android:textColor="@color/on_surface"
            tools:text="Trending Now" />

        <!-- Hidden by default — show in code when needed -->
        <TextView
            android:id="@+id/tv_view_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:text="VIEW ALL →"
            android:textColor="@color/primary"
            android:visibility="gone"
            style="@style/TextAppearance.NeonNoir.LabelCaps" />

    </LinearLayout>

    <!-- Optional subtitle — hidden by default -->
    <TextView
        android:id="@+id/tv_section_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:visibility="gone"
        style="@style/TextAppearance.NeonNoir.BodyMedium"
        android:textColor="@color/on_surface_variant"
        tools:text="Most watched in your region" />

</LinearLayout>