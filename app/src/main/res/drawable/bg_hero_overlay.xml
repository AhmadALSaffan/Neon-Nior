<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom-to-top dark gradient for text legibility -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#E6000000"
                android:centerColor="#80000000"
                android:endColor="#00000000"
                android:type="linear" />
        </shape>
    </item>
    <!-- Subtle left-to-right vignette -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#33000000"
                android:endColor="#00000000"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
