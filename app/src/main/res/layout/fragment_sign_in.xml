<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- Logo -->
        <TextView
            android:id="@+id/tv_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_padding_horizontal"
            android:layout_marginTop="20dp"
            android:text="NEON NOIR"
            android:textSize="20sp"
            android:textColor="@color/primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_new_here"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="new here?"
            style="@style/TextAppearance.NeonNoir.BodyMedium"
            app:layout_constraintTop_toTopOf="@+id/tv_logo"
            app:layout_constraintBottom_toBottomOf="@+id/tv_logo"
            app:layout_constraintEnd_toStartOf="@+id/tv_sign_up_link" />

        <TextView
            android:id="@+id/tv_sign_up_link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/screen_padding_horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="SIGN UP"
            android:textColor="@color/primary"
            style="@style/TextAppearance.NeonNoir.LabelCaps"
            app:layout_constraintTop_toTopOf="@+id/tv_logo"
            app:layout_constraintBottom_toBottomOf="@+id/tv_logo"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Sign In Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_sign_in"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_padding_horizontal"
            android:layout_marginEnd="@dimen/screen_padding_horizontal"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/surface_container_low"
            app:cardCornerRadius="@dimen/radius_xl"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Gradient accent top bar -->
                <View
                    android:id="@+id/v_gradient_bar"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@drawable/bg_gradient_brand" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="28dp">

                    <TextView
                        android:id="@+id/tv_welcome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Welcome Back"
                        android:gravity="center"
                        style="@style/TextAppearance.NeonNoir.HeadlineLarge" />

                    <TextView
                        android:id="@+id/tv_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Sign in to access your curated library."
                        android:gravity="center"
                        style="@style/TextAppearance.NeonNoir.BodyMedium" />

                    <!-- Email label -->
                    <TextView
                        android:id="@+id/tv_label_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:text="EMAIL OR USERNAME"
                        style="@style/TextAppearance.NeonNoir.LabelCaps" />

                    <!-- Email input -->
                    <EditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_default"
                        android:hint="name@example.com"
                        android:inputType="textEmailAddress"
                        android:drawableStart="@drawable/ic_email"
                        android:drawablePadding="10dp"
                        android:drawableTint="@color/on_surface_variant"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/on_surface_variant"
                        style="@style/TextAppearance.NeonNoir.BodyMedium" />

                    <!-- Password row label + forgot link -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="20dp">

                        <TextView
                            android:id="@+id/tv_label_password"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="PASSWORD"
                            style="@style/TextAppearance.NeonNoir.LabelCaps" />

                        <TextView
                            android:id="@+id/tv_forgot"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Forgot Password?"
                            android:textColor="@color/secondary"
                            style="@style/TextAppearance.NeonNoir.LabelMedium" />

                    </LinearLayout>

                    <!-- Password input -->
                    <EditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_default"
                        android:inputType="textPassword"
                        android:drawableStart="@drawable/ic_lock"
                        android:drawableEnd="@drawable/ic_eye"
                        android:drawablePadding="10dp"
                        android:drawableTint="@color/on_surface_variant"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/on_surface"
                        style="@style/TextAppearance.NeonNoir.BodyMedium" />

                    <!-- Sign In button -->
                    <Button
                        android:id="@+id/btn_sign_in"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_button_primary"
                        android:text="Sign In →"
                        android:textColor="@color/on_primary"
                        android:textSize="14sp"
                        android:stateListAnimator="@null" />

                    <!-- OR CONTINUE WITH divider -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="24dp">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="@color/surface_container_high" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            android:text="OR CONTINUE WITH"
                            style="@style/TextAppearance.NeonNoir.LabelCaps" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="@color/surface_container_high" />

                    </LinearLayout>


                    <Button
                        android:id="@+id/btn_google"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_card"
                        android:drawableEnd="@drawable/ic_google"
                        android:drawablePadding="50dp"
                        android:paddingEnd="50dp"
                        android:text="Google"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:stateListAnimator="@null" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Terms of Service footer -->
        <TextView
            android:id="@+id/tv_terms"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="@dimen/screen_padding_horizontal"
            android:layout_marginEnd="@dimen/screen_padding_horizontal"
            android:text="By continuing, you agree to our Terms of Service and Privacy Policy."
            android:gravity="center"
            style="@style/TextAppearance.NeonNoir.BodySmall"
            app:layout_constraintTop_toBottomOf="@+id/card_sign_in"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Copyright -->
        <TextView
            android:id="@+id/tv_copyright"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="@dimen/screen_padding_horizontal"
            android:layout_marginEnd="@dimen/screen_padding_horizontal"
            android:text="© 2024 NEON NOIR ENTERTAINMENT. ALL RIGHTS RESERVED."
            android:gravity="center"
            style="@style/TextAppearance.NeonNoir.LabelCaps"
            app:layout_constraintTop_toBottomOf="@+id/tv_terms"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>