<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".presentation.profile.ProfileFragment">

    <!-- ═══════════════════════════════════════════ -->
    <!-- APP BAR                                     -->
    <!-- ═══════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Profile"
                style="@style/TextAppearance.NeonNoir.HeadlineSmall"
                android:textColor="@color/on_surface" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="end"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings"
                android:src="@drawable/ic_settings"
                app:tint="@color/primary" />

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ═══════════════════════════════════════════ -->
    <!-- SCROLLABLE CONTENT                          -->
    <!-- ═══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/bottom_nav_height"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_padding_horizontal">

            <!-- ─────────────────────────────────── -->
            <!-- PROFILE HERO CARD                   -->
            <!-- ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="@dimen/spacing_6"
                android:gravity="center">

                <!-- Avatar with gradient ring + verified badge -->
                <FrameLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp">

                    <!-- Gradient ring background -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/shape_avatar_ring" />

                    <!-- Avatar image, inset 4dp to show ring -->
                    <ImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        android:layout_gravity="center"
                        android:background="@drawable/shape_circle"
                        android:scaleType="centerCrop"
                        android:contentDescription="Profile avatar"
                        tools:src="@tools:sample/avatars" />

                    <!-- Verified badge — bottom right -->
                    <LinearLayout
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="2dp"
                        android:background="@drawable/bg_badge_premiere"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/primary"
                            android:contentDescription="@null" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Display Name -->
                <TextView
                    android:id="@+id/tv_display_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_4"
                    android:textAllCaps="true"
                    android:textStyle="bold"
                    style="@style/TextAppearance.NeonNoir.HeadlineLarge"
                    android:textColor="@color/on_surface"
                    tools:text="JOHN WICK" />

                <!-- Premium badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_2"
                    android:text="PREMIUM MEMBER"
                    android:paddingStart="@dimen/spacing_4"
                    android:paddingEnd="@dimen/spacing_4"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:background="@drawable/bg_badge_premiere"
                    style="@style/TextAppearance.NeonNoir.LabelCaps"
                    android:textColor="@color/primary" />

                <!-- Bio / quote -->
                <TextView
                    android:id="@+id/tv_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_3"
                    android:gravity="center"
                    style="@style/TextAppearance.NeonNoir.BodyMedium"
                    android:textColor="@color/on_surface_variant"
                    tools:text="user@email.com" />

            </LinearLayout>

            <!-- ─────────────────────────────────── -->
            <!-- STATS GRID (2×2)                    -->
            <!-- ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_4"
                android:orientation="vertical">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Movies Watched -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/spacing_2"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card"
                        android:padding="@dimen/spacing_5">

                        <TextView
                            android:id="@+id/tv_history_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextAppearance.NeonNoir.HeadlineLarge"
                            android:textColor="@color/primary"
                            tools:text="248" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="MOVIES WATCHED"
                            style="@style/TextAppearance.NeonNoir.LabelCaps"
                            android:textColor="@color/on_surface_variant"
                            android:gravity="center" />

                    </LinearLayout>

                    <!-- In Watchlist -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_2"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card"
                        android:padding="@dimen/spacing_5">

                        <TextView
                            android:id="@+id/tv_watchlist_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextAppearance.NeonNoir.HeadlineLarge"
                            android:textColor="@color/secondary"
                            tools:text="42" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="IN WATCHLIST"
                            style="@style/TextAppearance.NeonNoir.LabelCaps"
                            android:textColor="@color/on_surface_variant"
                            android:gravity="center" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_2"
                    android:orientation="horizontal">

                    <!-- Reviews placeholder -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/spacing_2"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card"
                        android:padding="@dimen/spacing_5">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            style="@style/TextAppearance.NeonNoir.HeadlineLarge"
                            android:textColor="@color/tertiary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="REVIEWS"
                            style="@style/TextAppearance.NeonNoir.LabelCaps"
                            android:textColor="@color/on_surface_variant"
                            android:gravity="center" />

                    </LinearLayout>

                    <!-- Favorite Genres -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_2"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_card"
                        android:padding="@dimen/spacing_5">

                        <!-- Overlapping genre bubbles -->
                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="32dp">

                            <TextView
                                android:id="@+id/tv_genre_1"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="0dp"
                                android:background="@drawable/bg_icon_primary"
                                android:gravity="center"
                                android:text="ACT"
                                style="@style/TextAppearance.NeonNoir.LabelSmall"
                                android:textColor="@color/primary" />

                            <TextView
                                android:id="@+id/tv_genre_2"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="20dp"
                                android:background="@drawable/bg_icon_secondary"
                                android:gravity="center"
                                android:text="NOI"
                                style="@style/TextAppearance.NeonNoir.LabelSmall"
                                android:textColor="@color/secondary" />

                            <TextView
                                android:id="@+id/tv_genre_3"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginStart="40dp"
                                android:background="@drawable/bg_icon_tertiary"
                                android:gravity="center"
                                android:text="THR"
                                style="@style/TextAppearance.NeonNoir.LabelSmall"
                                android:textColor="@color/tertiary" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_2"
                            android:text="FAVORITE GENRES"
                            style="@style/TextAppearance.NeonNoir.LabelCaps"
                            android:textColor="@color/on_surface_variant"
                            android:gravity="center" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ─────────────────────────────────── -->
            <!-- CONTINUE WATCHING                   -->
            <!-- ─────────────────────────────────── -->
            <include
                android:id="@+id/header_continue"
                layout="@layout/view_section_header" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_continue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/row_gap"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingStart="0dp"
                android:paddingEnd="@dimen/screen_padding_horizontal"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Empty state for Continue Watching -->
            <TextView
                android:id="@+id/tv_empty_continue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_4"
                android:gravity="center"
                android:text="Nothing in progress yet"
                style="@style/TextAppearance.NeonNoir.BodyMedium"
                android:textColor="@color/on_surface_variant"
                android:visibility="gone" />

            <!-- ─────────────────────────────────── -->
            <!-- ACCOUNT & SETTINGS                  -->
            <!-- ─────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/section_gap"
                android:layout_marginBottom="@dimen/spacing_4"
                android:text="Account &amp; Settings"
                style="@style/TextAppearance.NeonNoir.HeadlineSmall"
                android:textColor="@color/on_surface" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card">

                <!-- Account Settings -->
                <LinearLayout
                    android:id="@+id/row_account"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_5"
                    android:background="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_primary"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_person"
                            app:tint="@color/primary"
                            android:contentDescription="@null" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_4">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Account Settings"
                            style="@style/TextAppearance.NeonNoir.BodyMedium"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Update email, password, and security"
                            style="@style/TextAppearance.NeonNoir.LabelSmall"
                            android:textColor="@color/on_surface_variant" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_back"
                        android:rotation="180"
                        app:tint="@color/on_surface_variant"
                        android:contentDescription="@null" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/ghost_border" />

                <!-- Preferences -->
                <LinearLayout
                    android:id="@+id/row_preferences"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_5"
                    android:background="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_secondary"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_tune"
                            app:tint="@color/secondary"
                            android:contentDescription="@null" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_4">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Preferences"
                            style="@style/TextAppearance.NeonNoir.BodyMedium"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manage playback, language, and subtitles"
                            style="@style/TextAppearance.NeonNoir.LabelSmall"
                            android:textColor="@color/on_surface_variant" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_back"
                        android:rotation="180"
                        app:tint="@color/on_surface_variant"
                        android:contentDescription="@null" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/ghost_border" />

                <!-- Help & Support -->
                <LinearLayout
                    android:id="@+id/row_help"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_5"
                    android:background="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_tertiary"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_help"
                            app:tint="@color/tertiary"
                            android:contentDescription="@null" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_4">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Help &amp; Support"
                            style="@style/TextAppearance.NeonNoir.BodyMedium"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FAQs, chat support, and legal terms"
                            style="@style/TextAppearance.NeonNoir.LabelSmall"
                            android:textColor="@color/on_surface_variant" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_back"
                        android:rotation="180"
                        app:tint="@color/on_surface_variant"
                        android:contentDescription="@null" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/ghost_border" />

                <!-- Log Out -->
                <LinearLayout
                    android:id="@+id/row_logout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_5"
                    android:background="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_error"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_login"
                            app:tint="@color/error"
                            android:contentDescription="@null" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/spacing_4">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Log Out"
                            style="@style/TextAppearance.NeonNoir.BodyMedium"
                            android:textColor="@color/error" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="See you later, space cowboy"
                            style="@style/TextAppearance.NeonNoir.LabelSmall"
                            android:textColor="@color/on_surface_variant" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Bottom breathing room -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="@dimen/section_gap" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
