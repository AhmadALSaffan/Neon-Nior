<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- NEON NOIR logo -->
        <TextView
            android:id="@+id/tv_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="NEON NOIR"
            android:textStyle="italic"
            android:textSize="28sp"
            android:textColor="@color/primary"
            android:textAllCaps="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="THE DIGITAL PREMIERE AWAITS"
            style="@style/TextAppearance.NeonNoir.LabelCaps"
            app:layout_constraintTop_toBottomOf="@+id/tv_logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Form Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_form"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/surface_container_low"
            app:cardCornerRadius="@dimen/radius_xl"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_tagline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create Account"
                    style="@style/TextAppearance.NeonNoir.HeadlineLarge" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Join the elite circle of cinematic curators."
                    style="@style/TextAppearance.NeonNoir.BodyMedium" />

                <!-- FULL NAME -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="FULL NAME"
                    style="@style/TextAppearance.NeonNoir.LabelCaps" />

                <EditText
                    android:id="@+id/et_full_name"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_default"
                    android:hint="Enter your full name"
                    android:inputType="textPersonName"
                    android:drawableStart="@drawable/ic_person"
                    android:drawablePadding="10dp"
                    android:drawableTint="@color/on_surface_variant"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/on_surface_variant"
                    style="@style/TextAppearance.NeonNoir.BodyMedium" />

                <!-- EMAIL ADDRESS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="EMAIL ADDRESS"
                    style="@style/TextAppearance.NeonNoir.LabelCaps" />

                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_default"
                    android:hint="name@example.com"
                    android:inputType="textEmailAddress"
                    android:drawableStart="@drawable/ic_email"
                    android:drawablePadding="10dp"
                    android:drawableTint="@color/on_surface_variant"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/on_surface_variant"
                    style="@style/TextAppearance.NeonNoir.BodyMedium" />

                <!-- PASSWORD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="PASSWORD"
                    style="@style/TextAppearance.NeonNoir.LabelCaps" />

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_default"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:drawableStart="@drawable/ic_lock"
                    android:drawablePadding="10dp"
                    android:drawableTint="@color/on_surface_variant"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/on_surface_variant"
                    style="@style/TextAppearance.NeonNoir.BodyMedium" />

                <!-- CONFIRM PASSWORD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="CONFIRM"
                    style="@style/TextAppearance.NeonNoir.LabelCaps" />

                <EditText
                    android:id="@+id/et_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_default"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:drawableStart="@drawable/ic_shield"
                    android:drawablePadding="10dp"
                    android:drawableTint="@color/on_surface_variant"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/on_surface"
                    android:textColorHint="@color/on_surface_variant"
                    style="@style/TextAppearance.NeonNoir.BodyMedium" />

                <!-- Terms checkbox -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp">

                    <CheckBox
                        android:id="@+id/cb_terms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/secondary" />

                    <TextView
                        android:id="@+id/tv_terms"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="I agree to the Terms of Service and Privacy Policy."
                        style="@style/TextAppearance.NeonNoir.BodySmall" />

                </LinearLayout>

                <!-- Error message -->
                <TextView
                    android:id="@+id/tv_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/error"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <!-- SIGN UP button -->
                <Button
                    android:id="@+id/btn_sign_up"
                    style="@style/Widget.AppCompat.Button"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="SIGN UP →"
                    android:textColor="@color/on_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"
                    android:outlineProvider="none" />

                <!-- Loading indicator -->
                <ProgressBar
                    android:id="@+id/progress_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:indeterminateTint="@color/primary"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Already have account -->
        <TextView
            android:id="@+id/tv_already"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Already have an account?"
            style="@style/TextAppearance.NeonNoir.BodyMedium"
            app:layout_constraintTop_toBottomOf="@+id/card_form"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btn_sign_in"
            style="@style/Widget.AppCompat.Button"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_ghost"
            android:drawableStart="@drawable/ic_login"
            android:drawablePadding="8dp"
            android:drawableTint="@color/on_surface"
            android:text="Sign In"
            android:textColor="@color/on_surface"
            android:textSize="14sp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:stateListAnimator="@null"
            android:elevation="0dp"
            android:outlineProvider="none"
            app:layout_constraintTop_toBottomOf="@+id/tv_already"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Decorative footer icons -->
        <LinearLayout
            android:id="@+id/ll_footer_icons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@+id/btn_sign_in"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_clapperboard"
                android:alpha="0.4" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_screen"
                android:alpha="0.4" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_filmstrip"
                android:alpha="0.4" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_hq"
                android:alpha="0.4" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>