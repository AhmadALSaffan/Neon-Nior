<?xml version="1.0" encoding="utf-8"?>
<!-- Portrait movie card — used in rv_trending and rv_recent (horizontal scroll) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="148dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginEnd="@dimen/card_gap">

    <!-- Poster card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="210dp"
        app:cardBackgroundColor="@color/surface_container"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="@dimen/elevation_card">

        <!-- Poster image -->
        <ImageView
            android:id="@+id/iv_poster"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            tools:src="@tools:sample/backgrounds/scenic" />

        <!-- Rating badge — top right overlay -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:background="@drawable/bg_badge_dark"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="5dp"
            android:paddingTop="3dp"
            android:paddingEnd="6dp"
            android:paddingBottom="3dp">

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/ic_star_small"
                app:tint="@color/primary"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tv_rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                style="@style/TextAppearance.NeonNoir.LabelSmall"
                android:textColor="@color/on_surface"
                tools:text="8.4" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Title — below the card -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="1"
        android:ellipsize="end"
        style="@style/TextAppearance.NeonNoir.BodyMedium"
        android:textColor="@color/on_surface"
        tools:text="The Silent Echo" />

    <!-- Meta — genre + year -->
    <TextView
        android:id="@+id/tv_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:maxLines="1"
        android:ellipsize="end"
        style="@style/TextAppearance.NeonNoir.LabelSmall"
        android:textColor="@color/on_surface_variant"
        tools:text="Psychological • Thriller" />

</LinearLayout>